# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev: a local Postgres or a free Neon branch.
# Production (Vercel): set these in Project → Settings → Environment Variables.
#
# Neon gives you two connection strings:
#   • Pooled  (host contains "-pooler") → DATABASE_URL  (used at runtime)
#   • Direct  (no "-pooler")            → DIRECT_URL     (used for migrations)
# If your provider has no separate direct URL, set both to the same value.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
