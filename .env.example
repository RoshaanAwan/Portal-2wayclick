# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev: a local Postgres or a free Neon branch.
# Production (Vercel): set these in Project → Settings → Environment Variables.
#
# Neon gives you two connection strings:
#   • Pooled  (host contains "-pooler") → DATABASE_URL  (used at runtime)
#   • Direct  (no "-pooler")            → DIRECT_URL     (used for migrations)
# If your provider has no separate direct URL, set both to the same value.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── AI assistant (OpenAI) ─────────────────────────────────────────────────────
# Powers the floating bottom-right Portal Assistant. Server-side only — never
# exposed to the browser. Get a key at https://platform.openai.com/api-keys and
# put the real value in .env.local (gitignored), or in Vercel env vars for prod.
# Without it, the assistant returns a friendly "not configured" message.
OPENAI_API_KEY="sk-..."

# ── Slack attendance bot ──────────────────────────────────────────────────────
# Shared secret the local Slack bot sends as `Authorization: Bearer <secret>`
# when forwarding check-in / check-out events to POST /api/attendance/slack.
# Generate a strong random value (e.g. `openssl rand -hex 32`) and set the SAME
# value here (Vercel env vars for prod) and in the bot's config. Requests
# without a matching secret are rejected with 401. See docs/slack-attendance.md.
SLACK_BOT_SECRET="generate-a-long-random-string"

# ── Attendance end-of-day sweep cron ──────────────────────────────────────────
# Gates GET/POST /api/attendance/sweep, which force-closes any break left open
# for a past day (no break_out received) so it doesn't dangle. Hit once daily by
# a scheduler. On Vercel, set this env var and Vercel Cron auto-sends it as
# `Authorization: Bearer <CRON_SECRET>` (see vercel.json). Generate with
# `openssl rand -hex 32`. Optional: without it the route 401s; the primary
# auto-close on check-out still works, so the sweep is only a safety net.
CRON_SECRET="generate-a-long-random-string"

# ── Stripe (client invoice payments) ──────────────────────────────────────────
# Lets clients pay an invoice online from its public share page via Stripe
# Checkout. Optional — without these, the "Pay now" button simply doesn't show
# and invoices still work (view / download / share). Server-side only.
#
# TEST vs LIVE is decided purely by which secret key you paste (sk_test_… now,
# sk_live_… when you go live). Get keys at https://dashboard.stripe.com/apikeys.
#
#   STRIPE_SECRET_KEY     — your secret API key (sk_test_… / sk_live_…)
#   STRIPE_WEBHOOK_SECRET — the signing secret (whsec_…) for the webhook
#                           endpoint POST /api/stripe/webhook. Create the
#                           endpoint in Dashboard → Developers → Webhooks and
#                           subscribe to `checkout.session.completed` (and
#                           `checkout.session.async_payment_succeeded`). For
#                           local testing use the Stripe CLI:
#                             stripe listen --forward-to localhost:3000/api/stripe/webhook
#                           which prints the whsec_… to use here.
# See docs/stripe-payments.md for the full setup walkthrough.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── JazzCash (one-off, pay-per-period billing) ────────────────────────────────
# Optional local Pakistani payment gateway, offered ALONGSIDE Stripe on the
# billing page ("Pay with JazzCash"). JazzCash has no recurring subscriptions, so
# a payment buys ONE plan period: on a verified success the tenant goes "active"
# with currentPeriodEnd = now + the plan's interval; renewal is a fresh payment.
# Plans sold via JazzCash are charged in PKR (their priceCents is treated as PKR).
#
# TEST vs LIVE is decided purely by which ENDPOINT + credentials you set (sandbox
# now, payments.jazzcash.com.pk when live). Get credentials from your JazzCash
# merchant portal.
#
#   JAZZCASH_MERCHANT_ID — your merchant id (e.g. MC819335)
#   JAZZCASH_PASSWORD    — the merchant password
#   JAZZCASH_HASH_KEY    — the Integrity Salt used to HMAC-SHA256 sign requests and
#                          verify the signed return POST to /api/billing/jazzcash/callback
#   JAZZCASH_ENDPOINT    — the hosted merchant form URL to POST to
#   JAZZCASH_RETURN_URL  — informational (the actual return URL is built per-tenant
#                          to the callback route; set to your billing page)
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_HASH_KEY=""
JAZZCASH_RETURN_URL="https://portal.example.com/billing"
JAZZCASH_ENDPOINT="https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform"

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a keypair: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Set the SAME public key in both VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ── White-label branding ──────────────────────────────────────────────────────
# These set the DEFAULT brand for the deployment (lib/brand.ts). They work on the
# first boot, server-side, and in places a DB read isn't possible. An Admin can
# override any of them at runtime in /admin/branding (stored in BrandingSettings,
# no redeploy) — those overrides win over these.
#
# NEXT_PUBLIC_* values are inlined into the client bundle at build time, so a
# change requires a rebuild. All are optional; unset falls back to the 2WayClick
# defaults baked into lib/brand.ts.
#
# Custom logo upload (admin Branding page) uses Vercel Blob when configured, else
# an inline data-URL fallback — see BLOB_READ_WRITE_TOKEN below.
NEXT_PUBLIC_BRAND_NAME="2WayClick"
NEXT_PUBLIC_BRAND_LEGAL="2WayClick"          # copyright/legal name (defaults to BRAND_NAME)
NEXT_PUBLIC_BRAND_TAGLINE="Company Portal"
NEXT_PUBLIC_BRAND_WEBSITE="2wayclick.com"
NEXT_PUBLIC_BRAND_EMAIL_DOMAIN="2wayclick.com"
NEXT_PUBLIC_BRAND_LOGO_URL=""                # optional hosted logo image; empty = built-in SVG mark
BRAND_ACCENT_HEX="#f5683f"                    # theme accent (#rrggbb); drives --c-accent* + PWA theme_color
BRAND_INVOICE_ACCENT=""                       # print-safe invoice accent; defaults to BRAND_ACCENT_HEX

# ── Vercel Blob (avatar + logo uploads) ───────────────────────────────────────
# Stores uploaded images (profile avatars, the brand logo) on Vercel Blob's CDN.
# Without it, uploads fall back to inline base64 data URLs (fine for local dev /
# small images). Get the token in Vercel → Storage → Blob.
BLOB_READ_WRITE_TOKEN=""

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
# The base domain that tenant subdomains hang off of: a tenant with subdomain
# "acme" is served at acme.<NEXT_PUBLIC_PORTAL_DOMAIN>. Middleware (middleware.ts)
# parses the request Host against this to resolve the tenant.
#
# Production: set to your domain (e.g. "portal.yourco.com") and point a WILDCARD
# DNS record (*.portal.yourco.com) + wildcard TLS at the app.
# Local dev: use "localhost:3000" (then visit acme.localhost:3000) or
# "lvh.me:3000" (acme.lvh.me:3000 — lvh.me resolves all subdomains to 127.0.0.1).
# Bare localhost / reserved labels (www, app, admin, api) carry no tenant.
NEXT_PUBLIC_PORTAL_DOMAIN="localhost:3000"

# DEV-ONLY convenience: fall back to this tenant's subdomain when a request has
# no subdomain (e.g. plain http://localhost:3000) so you can sign in locally
# without setting up *.lvh.me subdomains. HARD-DISABLED in production
# (NODE_ENV=production) and opt-in (does nothing unless set). Set to a tenant
# subdomain, e.g. "default". NEVER set this in production.
DEV_DEFAULT_TENANT=""

# Encrypts third-party integration credentials (e.g. GitHub token) at rest.
# Generate: node -e "console.log(require(\x27crypto\x27).randomBytes(32).toString(\x27hex\x27))"
INTEGRATIONS_SECRET=

# Signs the session cookie (a JWT wrapping the opaque session token). REQUIRED in
# production — the app throws on startup of any auth path if unset. Rotating it
# invalidates all existing session cookies (everyone must re-login).
# Generate: node -e "console.log(require(\x27crypto\x27).randomBytes(32).toString(\x27hex\x27))"
AUTH_JWT_SECRET=

# Google Drive integration (per-user "Connect your Drive" OAuth). Create an
# OAuth 2.0 Client (type: Web application) at console.cloud.google.com →
# APIs & Services → Credentials. Add the redirect URI below to the client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. Defaults to <request-origin>/api/integrations/google/callback, which
# works for localhost. Set explicitly in prod to your canonical host.
GOOGLE_OAUTH_REDIRECT_URI=

