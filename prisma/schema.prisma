// 2WayClick Portal — data model
// PostgreSQL in every environment. Locally, point DATABASE_URL at a local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon's pooled connection; Prisma uses the direct URL for migrations.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  title        String
  department   String
  // Role: SUPER_ADMIN | ADMIN | HR | LEAD | PROJECT_MANAGER | EMPLOYEE
  // (stored as a string; see lib/permissions.ts for the source of truth).
  role         String   @default("EMPLOYEE")
  avatarUrl    String?
  phone        String?
  location     String?
  bio          String?
  // Slack identity, used to attribute Slack check-in/out events to this user.
  // slackUserId is the stable Slack user ID (e.g. "U012ABCDEF"); slackHandle is
  // the human-friendly @name kept only for display/debugging. Either may be set
  // by an admin; the webhook also falls back to matching Slack email → email.
  slackUserId  String?  @unique
  slackHandle  String?
  startDate    DateTime @default(now())
  managerId    String?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]   @relation("ManagerReports")

  createdAt DateTime @default(now())

  // Relations
  sessions           Session[]
  authoredPosts      Announcement[]     @relation("PostAuthor")
  uploadedDocs       Document[]         @relation("DocUploader")
  leaveRequests      LeaveRequest[]     @relation("RequestOwner")
  reviewedRequests   LeaveRequest[]     @relation("RequestReviewer")
  comments           Comment[]
  reactions          Reaction[]
  activities         Activity[]
  readReceipts       AnnouncementRead[]
  createdTasks       Task[]             @relation("TaskCreator")
  taskAssignments    TaskAssignee[]
  taskComments       TaskComment[]
  ownedProjects      Project[]          @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  auditLogs          AuditLog[]         @relation("AuditActor")
  auditedBy          AuditLog[]         @relation("AuditTargetUser")
  notifications      Notification[]     @relation("NotifRecipient")
  triggeredNotifs    Notification[]     @relation("NotifActor")
  attendance         Attendance[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  category   String   @default("General") // General, Product, People, Policy, Event
  pinned     Boolean  @default(false)
  coverColor String   @default("accent")
  authorId   String
  author     User     @relation("PostAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())

  comments  Comment[]
  reactions Reaction[]
  reads     AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Comment {
  id             String       @id @default(cuid())
  body           String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())
}

model Reaction {
  id             String       @id @default(cuid())
  emoji          String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId, emoji])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("General") // HR, Engineering, Finance, Legal, Brand
  fileType    String   @default("pdf") // pdf, doc, sheet, slide, img
  sizeKb      Int      @default(0)
  url         String   @default("#")
  uploaderId  String
  uploader    User     @relation("DocUploader", fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())
}

model LeaveRequest {
  id         String    @id @default(cuid())
  type       String // Vacation, Sick, Personal, WFH
  startDate  DateTime
  endDate    DateTime
  reason     String?
  // Status: PENDING | APPROVED | DENIED
  status     String    @default("PENDING")
  ownerId    String
  owner      User      @relation("RequestOwner", fields: [ownerId], references: [id])
  reviewerId String?
  reviewer   User?     @relation("RequestReviewer", fields: [reviewerId], references: [id])
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?
}

// ── Attendance ───────────────────────────────────────────────────────────────
// One row per user per calendar day, driven by Slack check-in/check-out events
// the local bot forwards to POST /api/attendance/slack. The first check-in of a
// day opens the row (sets checkInAt + status PRESENT); a check-out stamps
// checkOutAt and sets status CHECKED_OUT. `day` is the date at midnight (server
// time) and is unique per user so repeated events update the same row instead of
// creating duplicates. See lib/attendance.ts for the recording logic.
model Attendance {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Calendar day this record covers, normalized to midnight (server time).
  day        DateTime
  // First check-in and most recent check-out for the day (null until they happen).
  checkInAt  DateTime?
  checkOutAt DateTime?
  // Status: PRESENT (checked in, not yet out) | CHECKED_OUT.
  status     String    @default("PRESENT")
  // Where the event came from, for provenance ("slack" today; room to grow).
  source     String    @default("slack")
  // Count of raw events received for the day (a person may check in/out twice).
  events     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // One row per person per day; lets the webhook upsert idempotently.
  @@unique([userId, day])
  // Newest-first lookups for the attendance dashboard.
  @@index([day])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verb      String // "posted", "uploaded", "requested", "approved", "joined", "commented"
  target    String // human-readable target
  meta      String? // optional JSON string
  createdAt DateTime @default(now())
}

// ── Audit log ────────────────────────────────────────────────────────────────
// The "track everything" trail for privileged actions. Distinct from Activity
// (which is the social/dashboard feed): AuditLog records WHO did WHAT to WHICH
// entity, with structured before/after detail and the request IP. Only viewable
// by Super Admin (see lib/permissions.ts → can.viewAuditLog).
model AuditLog {
  id           String  @id @default(cuid())
  // Who performed the action. Kept even if the actor is later deleted.
  actorId      String?
  actor        User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Denormalized actor identity so the log survives user deletion.
  actorName    String
  actorRole    String
  // What happened, e.g. "user.create", "user.role_change", "auth.login".
  action       String
  // The kind of entity touched, e.g. "User", "Project", "LeaveRequest".
  entity       String
  entityId     String?
  // Optional human-readable summary + structured JSON detail (before/after).
  summary      String?
  detail       String? // JSON string
  ip           String?
  userAgent    String?
  // Optional: the user this action was performed ON (e.g. the created user).
  targetUserId String?
  targetUser   User?   @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
}

// ── Task board (Trello-style) ──────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  lists   BoardList[]
  // A board may belong to a project (every project gets its own board). The
  // standalone /tasks board has no project.
  project Project?
}

// ── Projects ────────────────────────────────────────────────────────────────
// An admin-managed workspace. Each project owns exactly one board, giving it a
// separate Trello-style card section, and has its own roster of members.

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  // 1:1 with the board that holds this project's Trello cards.
  boardId String @unique
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  members ProjectMember[]
}

// Many-to-many join: which users belong to a project.
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([projectId, userId])
}

model BoardList {
  id        String   @id @default(cuid())
  name      String
  // Position of the list within its board (left → right).
  position  Float    @default(0)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  tasks Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  // Position of the card within its list (top → bottom). Fractional so cards
  // can be reordered without rewriting every sibling.
  position    Float     @default(0)
  // Priority: LOW | MEDIUM | HIGH
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  listId      String
  list        BoardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt   DateTime  @default(now())

  assignees TaskAssignee[]
  comments  TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

// ── Notifications ─────────────────────────────────────────────────────────────
// Per-user inbox. Distinct from Activity (a global social feed) and AuditLog
// (privileged-action trail): a Notification is addressed TO one user, carries a
// deep link to the thing that happened, and tracks its own read state. Written
// by lib/notifications.ts → notify(); surfaced in the topbar bell with a live
// (SSE) unread badge.
model Notification {
  id          String    @id @default(cuid())
  // Recipient — whose inbox this lands in.
  userId      String
  user        User      @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  // Who caused it (optional — system notifications have no actor). Denormalized
  // name/avatar are stored so the bell renders without a join even if the actor
  // is later deleted.
  actorId     String?
  actor       User?     @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName   String?
  actorAvatar String?
  // Kind, e.g. "leave.decided", "task.assigned", "task.comment",
  // "announcement.created". Keep grep-able and consistent.
  type        String
  // Human-readable line shown in the bell.
  message     String
  // In-app deep link to the relevant page, e.g. "/requests" or "/tasks".
  link        String?
  // Null until the user reads it.
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Newest-first lookups scoped to a recipient, and unread counts.
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Many-to-many join: who is assigned to a card (Trello "members").
model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
}
