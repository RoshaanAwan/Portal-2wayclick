// 2WayClick Portal — data model
// PostgreSQL in every environment. Locally, point DATABASE_URL at a local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon's pooled connection; Prisma uses the direct URL for migrations.
  directUrl = env("DIRECT_URL")
}

// ── Tenant (multi-tenancy root) ──────────────────────────────────────────────
// One row per customer workspace. Every tenant-scoped table carries a tenantId
// FK back here, and isolation is enforced app-side by the Prisma client
// extension (lib/db.ts) reading the per-request tenant from AsyncLocalStorage
// (lib/tenantContext.ts). The subdomain is the routing key: `acme` →
// acme.<NEXT_PUBLIC_PORTAL_DOMAIN>, resolved in middleware.ts.
model Tenant {
  id          String    @id @default(cuid())
  // Routing key. Lowercase DNS label; resolved from the request Host.
  subdomain   String    @unique
  name        String
  // "active" | "suspended". A suspended tenant is blocked at middleware.
  status      String    @default("active")
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Subscription (SaaS billing) ───────────────────────────────────────────
  // The package this tenant is subscribed to (System Owner catalog). Null = no
  // plan chosen yet. Plan is platform-level, NOT tenant-scoped.
  planId               String?
  plan                 Plan?     @relation(fields: [planId], references: [id])
  // Stripe mirror. We never compute billing locally — Stripe is the source of
  // truth and these are synced from webhooks. All globally unique.
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  // Mirrors Stripe's subscription.status verbatim: "trialing" | "active" |
  // "past_due" | "canceled" | "incomplete" | "unpaid". Null before first sub.
  subscriptionStatus   String?
  // End of the current paid/trial period — when access lapses if not renewed.
  currentPeriodEnd     DateTime?
  // Provisioning-time free trial granted by the System Owner at tenant creation
  // (independent of Stripe). The tenant has full access until this instant; once
  // it passes WITHOUT an active/trialing paid subscription, login is gated to the
  // billing page ("free trial ended, subscribe to continue"). Null = no trial
  // window (access depends solely on subscriptionStatus).
  trialEndsAt          DateTime?

  // JazzCash (one-off, pay-per-period). JazzCash has no recurring subscriptions,
  // so a payment buys a single plan period: on a verified payment we set
  // subscriptionStatus="active" + currentPeriodEnd = now + interval, and record
  // the gateway txn ref below so a replayed callback can't double-credit the same
  // payment. Renewal is a fresh JazzCash payment.
  jazzCashLastTxnRef   String?

  // Back-relations from every tenant-root model.
  users         User[]
  sessions      Session[]
  loginTickets  LoginTicket[]
  announcements Announcement[]
  boards        Board[]
  projects      Project[]
  tasks         Task[]
  invoices      Invoice[]
  auditLogs     AuditLog[]
  documents     Document[]
  activities    Activity[]
  conversations Conversation[]
  notifications Notification[]
  pushSubs      PushSubscription[]
  leaveRequests LeaveRequest[]
  attendance    Attendance[]
  attendanceBreaks AttendanceBreak[]
  expenses      Expense[]
  expenseCategories ExpenseCategory[]
  userSalaries  UserSalary[]
  branding      BrandingSettings?
  integrations  Integration[]
  driveConns    GoogleDriveConnection[]
  slackConn     SlackConnection?

  @@index([status])
}

// ── Plan (subscription package catalog) ───────────────────────────────────────
// Platform-level packages the System Owner defines and sells to tenants. NOT
// tenant-scoped: there is no tenantId and it is NOT in SCOPED_MODELS — only
// adminDb touches it, behind requireSystemOwner() (same posture as listTenants).
// Each plan mirrors a Stripe Product + recurring Price; the Stripe ids are the
// link used when a tenant subscribes via Checkout.
model Plan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  // Smallest currency unit (cents), same convention as Invoice.totalCents.
  priceCents      Int
  // ISO currency, lowercased for Stripe (e.g. "usd").
  currency        String   @default("usd")
  // Billing cadence: "month" | "year". Maps to Stripe's recurring.interval.
  interval        String   @default("month")
  // Free-trial length in days; 0 = no trial. Passed as trial_period_days.
  trialDays       Int      @default(0)
  // Optional hard cap on tenant users (enforced on user creation). Null = no cap.
  maxUsers        Int?
  // Human-readable feature bullets shown on the billing page (string[]).
  features        Json?
  // Stripe mirror — set when the plan is first saved. Price is immutable in
  // Stripe, so a price change creates a NEW price and swaps this id.
  stripeProductId String?  @unique
  stripePriceId   String?  @unique
  // Soft-archive instead of delete (a plan may still back live subscriptions).
  active          Boolean  @default(true)
  // Display order on the billing page (ascending).
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants Tenant[]

  @@index([active])
}

model User {
  id           String    @id @default(cuid())
  // Owning tenant. Email/slack uniqueness is per-tenant (see @@unique below).
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  title        String
  department   String
  // Role: SUPER_ADMIN | ADMIN | HR | LEAD | PROJECT_MANAGER | EMPLOYEE
  // (stored as a string; see lib/permissions.ts for the source of truth).
  role         String    @default("EMPLOYEE")
  // System Owner flag — a PLATFORM operator who manages tenants and NOTHING
  // else: no users/invoices/salaries/expenses/tasks in any tenant. Mutually
  // exclusive with a tenant business role: a System Owner lives in the reserved
  // "system" tenant with role EMPLOYEE (inert — every tenant check short-circuits
  // on this flag). Guarded by requireSystemOwner(); only platform routes use the
  // un-scoped client. A tenant's top admin (SUPER_ADMIN, "Company Owner") is
  // NEVER a System Owner.
  isSystemOwner Boolean @default(false)
  // DEPRECATED: kept transiently for a safe rollback during the System Owner
  // migration; backfilled into isSystemOwner. Dropped in a follow-up migration.
  isPlatformAdmin Boolean @default(false)
  avatarUrl    String?
  phone        String?
  location     String?
  bio          String?
  // Slack identity, used to attribute Slack check-in/out events to this user.
  // slackUserId is the stable Slack user ID (e.g. "U012ABCDEF"); slackHandle is
  // the human-friendly @name kept only for display/debugging. Either may be set
  // by an admin; the webhook also falls back to matching Slack email → email.
  // Per-tenant unique (see @@unique below) so tenants don't collide on Slack ids.
  slackUserId  String?
  slackHandle  String?
  startDate    DateTime  @default(now())
  // When set, the account is disabled: the user can't sign in and their active
  // sessions are revoked. Null = active. Reversible by an admin (re-enable).
  disabledAt   DateTime?
  managerId    String?
  manager      User?     @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]    @relation("ManagerReports")

  createdAt DateTime @default(now())

  // Relations
  sessions                Session[]
  approvedLogins          LoginTicket[]        @relation("LoginTicketApprover")
  authoredPosts           Announcement[]       @relation("PostAuthor")
  uploadedDocs            Document[]           @relation("DocUploader")
  leaveRequests           LeaveRequest[]       @relation("RequestOwner")
  reviewedRequests        LeaveRequest[]       @relation("RequestReviewer")
  comments                Comment[]
  reactions               Reaction[]
  activities              Activity[]
  readReceipts            AnnouncementRead[]
  createdTasks            Task[]               @relation("TaskCreator")
  reportedTasks           Task[]               @relation("TaskReporter")
  taskAssignments         TaskAssignee[]
  taskComments            TaskComment[]
  taskAttachments         TaskAttachment[]
  ownedProjects           Project[]            @relation("ProjectOwner")
  ledProjects             Project[]            @relation("ProjectLead")
  techLedProjects         Project[]            @relation("ProjectTechLead")
  projectMemberships      ProjectMember[]
  auditLogs               AuditLog[]           @relation("AuditActor")
  auditedBy               AuditLog[]           @relation("AuditTargetUser")
  notifications           Notification[]       @relation("NotifRecipient")
  triggeredNotifs         Notification[]       @relation("NotifActor")
  pushSubscriptions       PushSubscription[]   @relation("UserPushSubs")
  attendance              Attendance[]
  attendanceBreaks        AttendanceBreak[]
  createdInvoices         Invoice[]            @relation("InvoiceCreator")
  submittedExpenses       Expense[]            @relation("ExpenseSubmitter")
  reviewedExpenses        Expense[]            @relation("ExpenseReviewer")
  projectSalaries         ProjectSalary[]      @relation("SalaryEmployee")
  salary                  UserSalary?
  // Chat / messaging.
  conversationMemberships ConversationMember[] @relation("ConvMembership")
  sentMessages            Message[]            @relation("MessageSender")
  createdConversations    Conversation[]       @relation("ConversationCreator")
  driveConnection         GoogleDriveConnection?

  // The org tree is walked by managerId (Team Pulse, org chart, audit scope).
  // Postgres does not auto-index FK columns, so this is needed for the
  // `WHERE managerId IN (...)` subtree walks to use an index instead of a scan.
  @@index([managerId])
  @@index([tenantId])
  // Email + slack id are unique PER TENANT, so two tenants can have the same
  // address. Login always resolves the tenant from the subdomain first.
  @@unique([tenantId, email])
  @@unique([tenantId, slackUserId])
}

model Session {
  id        String   @id @default(cuid())
  // Token stays globally unique (256-bit random). tenantId is stored explicitly
  // so a bare-token lookup can be tenant-checked (getCurrentUser rejects a token
  // whose tenantId != the request's subdomain tenant) without a join.
  token     String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Set when a platform admin is impersonating: the platform user's id. Drives
  // the persistent "Impersonating" banner and audit trail.
  impersonatedBy String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Session FK lookup (e.g. cascade deletes, listing a user's sessions).
  @@index([userId])
  @@index([tenantId])
}

// Postgres-backed fixed-window rate limiter (lib/rateLimit.ts). One row per
// (bucket, windowStart): `bucket` identifies the limited subject — e.g.
// "login:ip:1.2.3.4", "login:email:a@b.com", "qr:create:ip:…", "share:<token>".
// `windowStart` is the start of the fixed time window. The counter is bumped via
// an atomic upsert+increment; rows older than their window are swept lazily. This
// works across serverless instances (unlike an in-process counter) using infra we
// already have (Neon), so no Redis/Upstash dependency is required.
model RateLimit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bucket      String
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime

  // One counter row per (bucket, window). The increment upserts on this.
  @@unique([bucket, windowStart])
  // Lazy cleanup of stale windows.
  @@index([expiresAt])
}

// QR "scan to sign in" handshake (WhatsApp-Web style). A new device shows a QR
// encoding this ticket's `token`; an already-authenticated phone scans it and
// approves; the new device then claims the ticket to mint a real Session.
//
// Lifecycle: PENDING → APPROVED → CONSUMED (terminal). Anything past `expiresAt`
// is dead. The token is single-use and short-lived (a couple of minutes). The
// approver is recorded so `claim` knows which user's session to mint — and so
// the approving device never has to hand its own session token to the new one.
model LoginTicket {
  id     String @id @default(cuid())
  // Token stays globally unique (random); tenant is bound at create and verified
  // on approve/claim so a ticket can only mint a session for its own tenant.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  token  String @unique
  // Direction of the handshake:
  //   SCAN_TO_APPROVE — a new device shows the QR; an already-signed-in phone
  //     scans + approves; the showing device then claims a session (login page).
  //   DIRECT_LINK — an already-signed-in device (dashboard) shows the QR bound
  //     to its own user; a NOT-signed-in phone scans it and signs itself in as
  //     that user. Created authenticated, so no separate approval step.
  kind   String @default("SCAN_TO_APPROVE")
  // PENDING | APPROVED | CONSUMED  (string to mirror the rest of the schema's
  // enum-as-string convention; see lib/permissions.ts for role precedent).
  status String @default("PENDING")

  // Set when an authenticated user approves the sign-in. SetNull on user delete
  // so a stray pending ticket never blocks account removal.
  approvedById String?
  approvedBy   User?     @relation("LoginTicketApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  // Coarse device hints captured from the requesting browser, shown to the
  // approver so they can sanity-check what they're authorizing.
  userAgent String?
  ipAddress String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  // Status sweeps / lookups: the poll and claim both query by token (unique,
  // already indexed); expiresAt supports cleanup of stale tickets.
  @@index([expiresAt])
  @@index([tenantId])
}

model Announcement {
  id         String   @id @default(cuid())
  // null = platform-wide announcement from System Owner (shown in every tenant feed)
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  body       String
  category   String   @default("General") // General, Product, People, Policy, Event
  pinned     Boolean  @default(false)
  coverColor String   @default("accent")
  // Optional calendar date this post pins to (e.g. a holiday or event day). When
  // set, the dashboard Calendar surfaces it on that day. Null = a plain feed post
  // with no calendar placement. Normalized to UTC midnight of the chosen date.
  eventDate  DateTime?
  // null for System Owner posts (no tenant user row); authorName stores display name
  authorId   String?
  author     User?    @relation("PostAuthor", fields: [authorId], references: [id])
  authorName String?  // used when authorId is null (system posts)
  createdAt  DateTime @default(now())

  comments  Comment[]
  reactions Reaction[]
  reads     AnnouncementRead[]

  // The feed orders by (pinned desc, createdAt desc); index the sort key.
  @@index([authorId])
  @@index([createdAt])
  // The calendar fetches posts in a date window; index the calendar date.
  @@index([eventDate])
  @@index([tenantId])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  // Compound unique covers announcementId lookups; index userId for "what has
  // this user read" and cascade deletes.
  @@unique([announcementId, userId])
  @@index([userId])
}

model Comment {
  id             String       @id @default(cuid())
  body           String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())

  // Comments are loaded per-announcement, oldest-first.
  @@index([announcementId, createdAt])
  @@index([authorId])
}

model Reaction {
  id             String       @id @default(cuid())
  emoji          String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The compound unique already covers announcementId-prefixed lookups.
  @@unique([announcementId, userId, emoji])
  @@index([userId])
}

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String   @default("General") // HR, Engineering, Finance, Legal, Brand
  fileType    String   @default("pdf") // pdf, doc, sheet, slide, img
  sizeKb      Int      @default(0)
  url         String   @default("#")
  uploaderId  String
  uploader    User     @relation("DocUploader", fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())

  // Library lists newest-first; uploader FK for join + "my uploads".
  @@index([createdAt])
  @@index([uploaderId])
  @@index([tenantId])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String // Vacation, Sick, Personal, WFH
  startDate  DateTime
  endDate    DateTime
  reason     String?
  // Status: PENDING | APPROVED | DENIED
  status     String    @default("PENDING")
  ownerId    String
  owner      User      @relation("RequestOwner", fields: [ownerId], references: [id])
  reviewerId String?
  reviewer   User?     @relation("RequestReviewer", fields: [reviewerId], references: [id])
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?

  // Team Pulse / org chart ask "who is on APPROVED leave covering today" for a
  // set of owners; the approvals queue filters PENDING. Index the hot paths.
  @@index([ownerId])
  @@index([status, startDate, endDate])
  @@index([reviewerId])
  // "My requests" filters ownerId and sorts newest-first — composite serves the
  // filter and the order together.
  @@index([ownerId, createdAt])
  @@index([tenantId])
}

// ── Attendance ───────────────────────────────────────────────────────────────
// One row per user per calendar day, driven by Slack check-in/check-out events
// the local bot forwards to POST /api/attendance/slack. The first check-in of a
// day opens the row (sets checkInAt + status PRESENT); a check-out stamps
// checkOutAt and sets status CHECKED_OUT. `day` is the date at midnight (server
// time) and is unique per user so repeated events update the same row instead of
// creating duplicates. See lib/attendance.ts for the recording logic.
model Attendance {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Calendar day this record covers, normalized to midnight (server time).
  day        DateTime
  // First check-in and most recent check-out for the day (null until they happen).
  checkInAt  DateTime?
  checkOutAt DateTime?
  // Status: PRESENT (checked in, not yet out) | CHECKED_OUT.
  status     String    @default("PRESENT")
  // Where the event came from, for provenance ("slack" today; room to grow).
  source     String    @default("slack")
  // Count of raw events received for the day (a person may check in/out twice).
  events     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Breaks taken during this day (lunch, etc.). Net worked time =
  // (checkOutAt − checkInAt) − sum(break durations). See lib/attendance.ts.
  breaks     AttendanceBreak[]

  // One row per person per day; lets the webhook upsert idempotently. userId
  // already implies the tenant, so this stays as-is.
  @@unique([userId, day])
  // Newest-first lookups for the attendance dashboard.
  @@index([day])
  @@index([tenantId])
}

// ── Attendance break ─────────────────────────────────────────────────────────
// One row per break a user takes during a day (they may take several). Opened by
// a Slack "break_in" event (breakInAt set, breakOutAt null = currently on break)
// and closed by "break_out" (breakOutAt stamped). The day's check-out, or an
// end-of-day sweep, auto-closes any still-open break so none dangles. Always
// linked to that day's Attendance row. See lib/attendance.ts.
model AttendanceBreak {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  // The attendance `day` key (UTC-midnight anchor of the PKT date), copied here
  // so breaks can be queried by day without a join.
  day          DateTime
  breakInAt    DateTime
  // Null while the break is open (user still away); stamped on break_out / sweep.
  breakOutAt   DateTime?
  // "slack" today; "sweep" when an end-of-day sweep force-closed a dangling break.
  source       String     @default("slack")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([attendanceId])
  // Fast "is there an open break for this user/day?" lookup.
  @@index([userId, day])
  @@index([tenantId])
}

// ── Slack webhook dedupe ─────────────────────────────────────────────────────
// The Slack bot may retry a delivery. We dedupe each event on its natural key
// (slackUserId, action, the Slack message ts) so a redelivery is a no-op rather
// than creating a duplicate break / double-counting. Rows are cheap and can be
// pruned by age later. Not tenant-scoped: the dedupe happens before user→tenant
// resolution, keyed on the Slack identity the bot sends. See attendance/slack.
model SlackWebhookEvent {
  id          String   @id @default(cuid())
  slackUserId String
  action      String
  // The raw Slack message ts as sent (e.g. "1719312000.000200").
  ts          String
  createdAt   DateTime @default(now())

  @@unique([slackUserId, action, ts])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verb      String // "posted", "uploaded", "requested", "approved", "joined", "commented"
  target    String // human-readable target
  meta      String? // optional JSON string
  createdAt DateTime @default(now())

  // Dashboard feed reads newest-first; userId for per-person activity joins.
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId])
}

// ── Audit log ────────────────────────────────────────────────────────────────
// The "track everything" trail for privileged actions. Distinct from Activity
// (which is the social/dashboard feed): AuditLog records WHO did WHAT to WHICH
// entity, with structured before/after detail and the request IP. Only viewable
// by Super Admin (see lib/permissions.ts → can.viewAuditLog).
model AuditLog {
  id           String  @id @default(cuid())
  // Explicit tenantId: actor/target are nullable SetNull, so the log can't
  // reliably inherit a tenant through a relation.
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Who performed the action. Kept even if the actor is later deleted.
  actorId      String?
  actor        User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Denormalized actor identity so the log survives user deletion.
  actorName    String
  actorRole    String
  // What happened, e.g. "user.create", "user.role_change", "auth.login".
  action       String
  // The kind of entity touched, e.g. "User", "Project", "LeaveRequest".
  entity       String
  entityId     String?
  // Optional human-readable summary + structured JSON detail (before/after).
  summary      String?
  detail       String? // JSON string
  ip           String?
  userAgent    String?
  // Optional: the user this action was performed ON (e.g. the created user).
  targetUserId String?
  targetUser   User?   @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@index([tenantId])
}

// ── Task board (Trello-style) ──────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  // ── JIRA-like issue keys ────────────────────────────────────────────────────
  // Every board has a short uppercase project key (e.g. "PORTAL", "WEB"). Each
  // card (issue) on the board gets a stable human id of `<keyPrefix>-<number>`,
  // where the number is drawn from `issueSeq` — a per-board monotonic counter
  // bumped atomically when a card is created (see lib/issues.ts → nextIssueKey).
  // keyPrefix defaults to a slug of the board/project name; issueSeq starts at 0
  // so the first issue is <prefix>-1.
  keyPrefix String @default("TASK")
  issueSeq  Int    @default(0)

  lists   BoardList[]
  sprints Sprint[]
  // A board may belong to a project (every project gets its own board). The
  // standalone /tasks board has no project.
  project Project?

  // The /tasks page loads the oldest board first.
  @@index([createdAt])
  @@index([tenantId])
}

// ── Sprints ─────────────────────────────────────────────────────────────────
// A named, time-boxed iteration on a board (JIRA-style). Cards are planned into
// a sprint via Task.sprintId; the Backlog is simply cards with no sprint. A
// board has at most one ACTIVE sprint at a time (enforced in lib/issues.ts);
// completing a sprint moves its still-open cards back to the backlog.
model Sprint {
  id          String    @id @default(cuid())
  boardId     String
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String
  goal        String?
  // PLANNED (in the backlog planner) | ACTIVE (started, drives the board) |
  // COMPLETED (closed). See SPRINT_STATUSES in lib/constants.ts.
  status      String    @default("PLANNED")
  startDate   DateTime?
  endDate     DateTime?
  // Set when the sprint is started / completed, for the timeline.
  startedAt   DateTime?
  completedAt DateTime?
  // Ordering of sprints within the backlog planner (top → bottom).
  position    Float     @default(0)
  createdAt   DateTime  @default(now())

  tasks Task[]

  @@index([boardId, status])
}

// ── Projects ────────────────────────────────────────────────────────────────
// An admin-managed workspace. Each project owns exactly one board, giving it a
// separate Trello-style card section, and has its own roster of members.

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())

  // Whether the project is active. Deactivating marks it inactive (shows an
  // "Inactive" badge) without removing it or hiding it from any list — a
  // reversible status flag, toggled by the admin tier from the projects page.
  active Boolean @default(true)

  // When set, the project is marked Completed (shows a "Completed" badge and
  // lives under the Completed tab). Independent of `active`: a project is shown
  // as Completed if this is set, otherwise Active/Inactive per `active`.
  // Reversible (set back to null) by the admin tier from the projects page.
  completedAt DateTime?

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  // Project lead (delivery/people owner) and tech lead (engineering owner).
  // Both optional — assignable at creation or later from the project page.
  // SetNull so removing the user doesn't delete the project; the seat just
  // empties. Distinct from `owner` (the admin who created/owns the record).
  projectLeadId String?
  projectLead   User?   @relation("ProjectLead", fields: [projectLeadId], references: [id], onDelete: SetNull)
  techLeadId    String?
  techLead      User?   @relation("ProjectTechLead", fields: [techLeadId], references: [id], onDelete: SetNull)

  // 1:1 with the board that holds this project's Trello cards.
  boardId String @unique
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  members ProjectMember[]

  // 1:1 with the chat channel auto-created for this project (kind="project").
  channel Conversation? @relation("ProjectChannel")

  // Public client-share link. Anyone with this opaque token can open a
  // read-only board at /shared/<token> and leave comments / submit requests
  // — no portal login. Nullable so it can be revoked (set to null) and
  // regenerated; @unique so the token is the lookup key. Set at creation.
  shareToken String? @unique

  // Comments & requests left by clients via the share link.
  clientSubmissions ClientSubmission[]

  // Finance: the project's income (one or more named lines — milestones,
  // retainers, etc.), the currency it and all derived money is in, the named
  // "share" lines carved out before payroll, the expenses charged to it, and
  // per-person salaries. revenueCents is a CACHE of sum(incomeLines.amountCents),
  // recomputed whenever a line changes (lib/financeQueries.ts), so the existing
  // share/pool math reads one number. The salary pool = revenue − sum(shares).
  revenueCents      Int                    @default(0)
  // CACHE of sum(active salaries' component amounts) — the committed payroll for
  // this project. Recomputed by recomputeProjectCommitted (lib/financeQueries.ts)
  // on every salary/component write, so finance reads return one integer instead
  // of hydrating every salary's components into Node to sum them.
  committedCents    Int                    @default(0)
  revenueCurrency   String                 @default("USD")
  incomeLines       ProjectIncomeLine[]
  shareLines        ProjectShareLine[]
  expenses          Expense[]
  salaries          ProjectSalary[]
  salaryAllocations UserSalaryAllocation[]

  @@index([ownerId])
  @@index([tenantId])
  // Projects list page filters by tenantId+active+completedAt and sorts by
  // createdAt desc — this composite covers both the filter and the sort so
  // Postgres never does a full tenant scan.
  @@index([tenantId, active, completedAt, createdAt(sort: Desc)])
}

// ── Client submissions ────────────────────────────────────────────────────────
// A comment or request left by an (unauthenticated) client through a project's
// public share link. Has no User — the client self-identifies with a free-text
// name, denormalized here. A REQUEST also spawns a Backlog card (taskId links
// the two); a COMMENT is attached to an existing card (taskId = the card).
model ClientSubmission {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // COMMENT (on an existing card) | REQUEST (becomes a new Backlog card).
  kind       String
  // Client-supplied display name, e.g. "Jane @ Acme". Never a portal identity.
  clientName String
  // For REQUEST: the request title. For COMMENT: null (body holds the text).
  title      String?
  body       String

  // The card this submission relates to: the commented card, or the card a
  // request spawned. SetNull (not Cascade) so deleting the card keeps the
  // client's words in the trail.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([taskId])
}

// Many-to-many join: which users belong to a project.
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  // Compound unique covers projectId lookups; index userId for "my projects".
  @@unique([projectId, userId])
  @@index([userId])
}

// ── Chat / messaging ──────────────────────────────────────────────────────────
// A conversation is a DM (two people), a named group, or a project channel
// (auto-tied to a Project, roster mirrors ProjectMember + owner). Messages are
// delivered live over the per-user `chat-user:<id>` bus (see lib/notifications.ts)
// and also fire a normal notification (bell + Web Push) so recipients are
// alerted when the app is closed. The Message row is the source of truth.
model Conversation {
  id   String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // "dm" | "group" | "project". Stored as a string (matches the Role / kind
  // convention elsewhere; see lib/messaging.ts for the source of truth).
  kind String

  // Group/channel display name. Null for DMs (rendered from the other member).
  title String?

  // For DMs: the sorted "minId:maxId" of the two members. Unique PER TENANT so a
  // DM between A and B can never be created twice (upsert collapses the race).
  // Null for groups and project channels. (member ids are already per-tenant,
  // but the composite keeps the constraint tenant-local and consistent.)
  dmKey String?

  // For project channels: the backing project (1:1). @unique so a project has
  // at most one channel. Null for DMs/groups.
  projectId String?  @unique
  project   Project? @relation("ProjectChannel", fields: [projectId], references: [id], onDelete: Cascade)

  // Who started it. SetNull so the thread survives the creator being deleted.
  createdById String?
  createdBy   User?   @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // Bumped on every send so the conversation list sorts by recent activity
  // without scanning Message. Defaults to creation time for empty threads.
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  members  ConversationMember[] @relation("ConvMembers")
  messages Message[]

  @@unique([tenantId, dmKey])
  @@index([lastMessageAt])
  @@index([tenantId])
}

// One row per (conversation, user). lastReadAt is a cheap per-member cursor:
// unread = count(messages with createdAt > lastReadAt and not mine), which is
// served by the Message [conversationId, createdAt] index — no per-message
// receipt rows. Defaults to the epoch so a freshly-added member sees existing
// history as unread without any app-side backfill.
model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation("ConvMembers", fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConvMembership", fields: [userId], references: [id], onDelete: Cascade)

  // Read cursor. lastReadMessageId is kept (nullable) so a future "read up to
  // here" divider is free; unread counting uses the timestamp.
  lastReadAt        DateTime @default(dbgenerated("'1970-01-01 00:00:00'::timestamp"))
  lastReadMessageId String?
  joinedAt          DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // SetNull + denormalized name/avatar so a deleted sender still renders in the
  // thread (mirrors Notification.actorName / Invoice / Expense).
  senderId     String?
  sender       User?   @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  senderName   String
  senderAvatar String?

  body      String
  createdAt DateTime @default(now())

  // Serves both keyset history paging and the unread range count.
  @@index([conversationId, createdAt])
  // /api/messages/since filters createdAt > cursor across ALL of a user's
  // conversations (no single conversationId), so the composite above can't drive
  // it — this is the hottest poll query. A bare createdAt index serves the range.
  @@index([createdAt])
  // senderId is SetNull on user delete; without an index that delete full-scans
  // this (the highest-volume) table.
  @@index([senderId])
}

model BoardList {
  id        String   @id @default(cuid())
  name      String
  // Position of the list within its board (left → right).
  position  Float    @default(0)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  tasks Task[]

  // Lists are read per-board ordered left→right.
  @@index([boardId, position])
}

model Task {
  id          String    @id @default(cuid())
  // Explicit tenantId (a root): issues.ts runs board-agnostic "my issues"
  // queries with no board/list in the where, so inheriting via Board isn't safe.
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  // Position of the card within its list (top → bottom). Fractional so cards
  // can be reordered without rewriting every sibling.
  position    Float     @default(0)
  // Priority: LOW | MEDIUM | HIGH
  priority    String    @default("MEDIUM")
  dueDate     DateTime?

  // ── JIRA-like issue fields ──────────────────────────────────────────────────
  // Per-board sequence number (drawn from Board.issueSeq). Combined with the
  // board's keyPrefix this renders the stable human key `<PREFIX>-<issueNumber>`
  // (e.g. PORTAL-42). Unique per board so the key is unambiguous. Nullable only
  // for the brief window before the create transaction assigns it / for legacy
  // rows the backfill hasn't reached.
  issueNumber Int?
  // Issue type: STORY | BUG | TASK | EPIC | SUBTASK. See ISSUE_TYPES.
  issueType   String   @default("TASK")
  // Workflow status: TODO | IN_PROGRESS | IN_REVIEW | DONE. This is the JIRA
  // lifecycle, kept in lock-step with the card's list (the Kanban column) — both
  // are written together so the board reads from the list and filters read from
  // status. See WORKFLOW_STATUSES + statusForList in lib/issues.ts.
  status      String   @default("TODO")
  // Agile estimate in story points (Fibonacci-ish). Distinct from
  // estimateMinutes (time). Null when unestimated.
  storyPoints Int?
  // Comma-free free-text labels, stored as a string array (Postgres text[]).
  labels      String[] @default([])

  // The person accountable for the issue (JIRA "reporter"), distinct from the
  // creator (who happens to have typed it in) and the assignees (who do it).
  // Defaults to the creator at create time; re-assignable by managers.
  reporterId String?
  reporter   User?   @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  // Optional sprint this issue is planned into. Null = backlog. SetNull so
  // deleting a sprint drops its cards back to the backlog rather than the cards.
  sprintId         String?
  sprint           Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  // Time estimate (minutes) set by whoever creates the card — the planned
  // effort, distinct from `timeSpentMinutes` (the actual logged time). Null
  // when no estimate was given.
  estimateMinutes  Int?
  // Manual time tracking ("time lock"). A single pool of minutes logged against
  // the card by anyone who can edit it; managers can adjust/reset the total.
  timeSpentMinutes Int       @default(0)
  listId           String
  list             BoardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creatorId        String
  creator          User      @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt        DateTime  @default(now())
  // When the card first reached a DONE column/status — the completion timestamp.
  // Set on the status→DONE transition (move/update routes), cleared if it leaves
  // DONE (reopened). Drives the Performance "delivered in period" + on-time math,
  // which createdAt alone can't answer. Null while the card is unfinished.
  completedAt      DateTime?

  assignees         TaskAssignee[]
  comments          TaskComment[]
  attachments       TaskAttachment[]
  // Client-share submissions tied to this card (the request that spawned it,
  // or comments left on it via the public link).
  clientSubmissions ClientSubmission[]

  // Issue links where this card is the source / the target. A link is directed
  // (BLOCKS, RELATES, DUPLICATES, PARENT) and rendered from both ends with the
  // inverse phrasing (see ISSUE_LINK_TYPES in lib/constants.ts).
  outgoingLinks IssueLink[] @relation("LinkSource")
  incomingLinks IssueLink[] @relation("LinkTarget")

  // Cards are read per-list ordered by position; creator FK for joins.
  @@index([listId, position])
  @@index([creatorId])
  @@index([sprintId])
  @@index([reporterId])
  @@index([status])
  // The issue-key route resolves a card by its number; uniqueness within a board
  // is guaranteed by the atomic Board.issueSeq counter (lib/issues.ts), so this
  // is a plain lookup index, not a constraint.
  @@index([issueNumber])
  @@index([tenantId])
  // Performance reads "tasks completed in [period]" per tenant.
  @@index([completedAt])
}

// ── Issue links ─────────────────────────────────────────────────────────────
// A directed relationship between two cards (JIRA "issue links"). `type` is one
// of ISSUE_LINK_TYPES. The same pair can be linked at most once per type+
// direction. Deleting either card removes the link (Cascade).
model IssueLink {
  id        String   @id @default(cuid())
  // BLOCKS | RELATES | DUPLICATES | PARENT. See ISSUE_LINK_TYPES.
  type      String
  sourceId  String
  source    Task     @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String
  target    Task     @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, type])
  @@index([targetId])
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  // Comments loaded per-task, oldest-first.
  @@index([taskId, createdAt])
  @@index([authorId])
}

// ── Card image attachments ────────────────────────────────────────────────────
// An image uploaded to a card (Trello "attachment"). The bytes live in the
// tenant's Google Drive (the company owner's connected Drive — the same storage
// backend documents/avatars use); `driveFileId` is the Drive file id and the
// portal streams it back through /api/tasks/attachment/proxy (the file is private
// to the drive.file scope, so a direct Drive link won't render). Deleting the row
// also deletes the Drive file. Cascade so removing a card cleans up its rows
// (the Drive files are best-effort cleaned by the delete route).
model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Drive file id — what the proxy streams and the delete route removes.
  driveFileId String
  // Original filename + MIME, for display and the proxy's Content-Type.
  name        String
  mimeType    String
  // Who uploaded it (for attribution + delete permission).
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())

  // Attachments loaded per-card, newest-first in the modal.
  @@index([taskId, createdAt])
  @@index([uploaderId])
}

// ── Notifications ─────────────────────────────────────────────────────────────
// Per-user inbox. Distinct from Activity (a global social feed) and AuditLog
// (privileged-action trail): a Notification is addressed TO one user, carries a
// deep link to the thing that happened, and tracks its own read state. Written
// by lib/notifications.ts → notify(); surfaced in the topbar bell with a live
// (SSE) unread badge.
model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Recipient — whose inbox this lands in.
  userId      String
  user        User      @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  // Who caused it (optional — system notifications have no actor). Denormalized
  // name/avatar are stored so the bell renders without a join even if the actor
  // is later deleted.
  actorId     String?
  actor       User?     @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName   String?
  actorAvatar String?
  // Kind, e.g. "leave.decided", "task.assigned", "task.comment",
  // "announcement.created". Keep grep-able and consistent.
  type        String
  // Human-readable line shown in the bell.
  message     String
  // In-app deep link to the relevant page, e.g. "/requests" or "/tasks".
  link        String?
  // Null until the user reads it.
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Newest-first lookups scoped to a recipient, and unread counts.
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([tenantId])
}

// A browser/device's Web Push subscription. One row per push endpoint; a user
// can have several (phone, laptop, …). Created when the user enables push in a
// given browser; deleted when they disable it or when the endpoint goes stale
// (the push service returns 404/410 and we prune it). See lib/push.ts.
model PushSubscription {
  id     String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserPushSubs", fields: [userId], references: [id], onDelete: Cascade)

  // The push service endpoint URL (unique per browser+origin) and the keys the
  // browser generated for encrypting payloads to it.
  endpoint String @unique
  p256dh   String
  auth     String

  // Coarse device label (from the User-Agent) so the user can tell their
  // subscriptions apart if we ever list them.
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
}

// ── Invoices ──────────────────────────────────────────────────────────────────
// A bill an Admin / Super Admin raises for a client and sends out. The client is
// captured as free-text (name + email + address) — there is no Client identity
// in the system; this mirrors ClientSubmission's denormalized client name.
//
// Money is stored as integer minor units (cents) in `currency`, never a float —
// 1234 + "USD" means $12.34. Totals are derived from the line items at write
// time and cached on the invoice (subtotalCents/taxCents/totalCents) so a
// printed/shared invoice is a stable snapshot even if rounding logic later
// changes. See lib/invoices.ts for the math, numbering, and formatting.
model Invoice {
  id     String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Human-facing sequential number, e.g. "INV-0007". Unique PER TENANT, assigned
  // at creation by counting the tenant's existing invoices (lib/invoices.ts →
  // nextNumber) — so each tenant gets its own INV-0001 sequence.
  number String

  // Free-text client (no portal identity). Email/address are optional.
  clientName    String
  clientEmail   String?
  clientAddress String?

  // Optional human note shown on the invoice (terms, thank-you, etc.).
  notes String?

  // Status: DRAFT (not yet finalized) | SENT (issued to client) | PAID |
  // CANCELLED. Drives the badge and which actions are offered.
  status String @default("DRAFT")

  // ISO 4217 currency code; all *Cents fields are in this currency's minor unit.
  currency String @default("USD")

  // Cached totals (minor units). Derived from items; recomputed on every edit.
  subtotalCents Int @default(0)
  // Tax as a basis-point rate (e.g. 825 = 8.25%) and the resulting amount.
  taxRateBps    Int @default(0)
  taxCents      Int @default(0)
  totalCents    Int @default(0)

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  // Stamped when status first moves to SENT (for "sent X ago").
  sentAt    DateTime?
  // Stamped when status moves to PAID.
  paidAt    DateTime?

  // Public, login-less link a client opens to view the invoice at
  // /invoices/shared/<token>. Opaque + unguessable; nullable so it can be
  // revoked/regenerated. @unique so the token is the lookup key.
  shareToken String? @unique

  // Stripe payment linkage. stripeSessionId is the most recent Checkout Session
  // opened for this invoice (used to resume an in-flight payment and to map a
  // webhook event back to the invoice); stripePaymentIntentId is stamped once a
  // payment succeeds, for reconciliation/refunds in the Stripe dashboard. Both
  // null until the client starts/finishes paying.
  stripeSessionId       String?
  stripePaymentIntentId String?

  // Who raised it. Kept (denormalized name) even if the user is later removed.
  creatorId   String?
  creator     User?   @relation("InvoiceCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  creatorName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InvoiceItem[]

  // The list orders newest-first; status filters the dashboard counts.
  @@index([createdAt])
  @@index([status])
  @@index([tenantId])
  // Invoice numbers are unique within a tenant, not globally.
  @@unique([tenantId, number])
}

// A single billable line on an invoice. Amounts are integer minor units.
model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description    String
  // Quantity is whole units (e.g. hours, licenses). Price is per-unit, in minor
  // units. amountCents is qty * unitPriceCents, cached so the row is a snapshot.
  quantity       Int    @default(1)
  unitPriceCents Int    @default(0)
  amountCents    Int    @default(0)
  // Display order of the line within the invoice (top → bottom).
  position       Int    @default(0)

  @@index([invoiceId, position])
}

// Many-to-many join: who is assigned to a card (Trello "members").
model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  // Compound unique covers taskId lookups. Team Pulse / org chart query
  // `WHERE userId IN (...)` to score each person's load, so index userId alone.
  @@unique([taskId, userId])
  @@index([userId])
}

// ── Finance: expenses ──────────────────────────────────────────────────────────
// An expense claim raised by an Admin-tier user and decided by a *different*
// Admin-tier user — same two-party approval shape as
// LeaveRequest. Money is integer minor units (cents) in `currency`, never a
// float, mirroring Invoice. An expense may optionally be charged to a Project
// (SetNull on project delete so the claim survives) and carry a receipt slip
// (url/name/size, uploaded via POST /api/finance/upload to Vercel Blob).
// See lib/finance.ts for the statuses, categories, money helpers, and validation.
model Expense {
  id    String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title String

  // One of lib/finance.ts → EXPENSE_CATEGORIES (Travel, Supplies, …). Stored as
  // a string; validated at write time.
  category String

  amountCents Int    @default(0)
  currency    String @default("USD")

  // Status: PENDING | APPROVED | REJECTED. Drives the badge + available actions.
  status String @default("PENDING")

  notes String?

  // The day the expense was incurred (date at midnight). Defaults to creation.
  spentOn DateTime @default(now())

  // Optional receipt slip (Vercel Blob URL or dev data URL) + its metadata.
  slipUrl    String?
  slipName   String?
  slipSizeKb Int?

  // Optional project this expense is charged to. SetNull so deleting a project
  // keeps the expense record (just unlinks it).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Who submitted it (denormalized name survives user deletion).
  submitterId   String?
  submitter     User?   @relation("ExpenseSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  submitterName String

  // Who decided it (null until decided). Denormalized name like the submitter.
  reviewerId   String?
  reviewer     User?     @relation("ExpenseReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerName String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The list orders newest-first; status filters the approval queue; projectId
  // for the per-project cost rollup; submitterId for "my claims".
  @@index([createdAt])
  @@index([status])
  @@index([projectId])
  @@index([submitterId])
  // Approval queue (filter status, sort createdAt) and per-project rollup
  // (filter projectId, sort createdAt) — composites so Postgres serves both the
  // filter and the order from one index instead of filtering then sorting.
  @@index([status, createdAt])
  @@index([projectId, createdAt])
  @@index([tenantId])
}

// ── Finance: custom expense categories ─────────────────────────────────────────
// Tenant-defined categories that extend the built-in EXPENSE_CATEGORIES list
// (lib/finance.ts). Created on the fly when someone submits an expense under a
// new category, so the dropdown remembers it next time. The built-in names are
// never stored here — only the custom additions. Unique per tenant (case is
// preserved but uniqueness is enforced on the stored string).
model ExpenseCategory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // The category label, e.g. "Subscriptions". Validated/normalized at write time.
  name     String
  // Who first introduced it (for attribution; nullable if that user is removed).
  createdById String?
  createdAt   DateTime @default(now())

  // One row per name per tenant; the dropdown lists these for the tenant.
  @@unique([tenantId, name])
  @@index([tenantId])
}

// ── Finance: per-project salaries ──────────────────────────────────────────────
// An employee's monthly salary on a given project. One employee may have a salary
// on several projects (and several rows over time as pay changes), so the cost of
// a project's payroll is the sum of its active salaries. Money is integer minor
// units (cents). Only ONE row per (project, employee) — editing pay updates the
// same row; superseding history is out of scope. Cascade on project delete (the
// salary has no meaning without its project); SetNull on user delete keeps the
// row (with the denormalized name) for the cost total.
model ProjectSalary {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // The employee this salary is for. SetNull on delete; name is denormalized.
  userId   String?
  user     User?   @relation("SalaryEmployee", fields: [userId], references: [id], onDelete: SetNull)
  userName String

  // The monthly salary is a list of NAMED components (e.g. "Dev", "BD", "Lead",
  // or any custom field an admin adds — "QA", "Bonus", …). The total monthly
  // pay is the SUM of its components (computed in the app, never stored, so it
  // can't drift). A salary with no components is zero. See lib/finance.ts.
  components SalaryComponent[]

  // Payments made against this salary (a running log). Paid = sum of payments;
  // remaining = salary total − paid. Cumulative, no monthly reset.
  payments SalaryPayment[]

  currency String @default("USD")

  // Whether this salary currently counts toward the project's payroll cost.
  // Deactivating (instead of deleting) keeps the record while excluding it.
  active Boolean @default(true)

  // The day this salary takes effect.
  effectiveFrom DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One salary row per person per project; reverse lookup "this person's
  // salaries"; index projectId for the per-project roster + cost rollup.
  // The (projectId, userName) unique keys the FREE-TEXT path: a salary typed by
  // name (userId null) is one-per-(project, name), so editing its cells upserts
  // the same row. Real-user rows still dedupe on (projectId, userId).
  @@unique([projectId, userId])
  @@unique([projectId, userName])
  @@index([projectId])
  @@index([userId])
}

// ── Finance: a named salary component ───────────────────────────────────────────
// One line of an employee's monthly pay on a project — a label ("Dev", "BD",
// "Lead", or any custom field) plus an amount in minor units. A salary's total
// is the sum of its components. Cascade-deleted with the salary; ordered for a
// stable display.
model SalaryComponent {
  id String @id @default(cuid())

  salaryId String
  salary   ProjectSalary @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  label       String
  amountCents Int    @default(0)

  // Optional Excel-style formula in canonical label form (e.g. "={Dev}*1.1").
  // null = a plain literal amount. Formulas reference OTHER COMPONENTS IN THE
  // SAME SALARY only; amountCents is the cached evaluated result (always kept in
  // sync by the same upsert), so every reader of amountCents stays correct. See
  // lib/formula.ts.
  formula String?

  // Display order within the salary (0-based).
  position Int @default(0)

  @@index([salaryId])
}

// ── Finance: a salary payment ───────────────────────────────────────────────────
// One payment made against a salary (a running log; no monthly reset). The amount
// paid so far = sum of a salary's payments; remaining = salary total − paid.
// Cascade-deleted with the salary; newest first by paidOn for display.
model SalaryPayment {
  id String @id @default(cuid())

  salaryId String
  salary   ProjectSalary @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  amountCents Int      @default(0)
  paidOn      DateTime @default(now())
  note        String?

  createdAt DateTime @default(now())

  @@index([salaryId])
}

// ── Payroll: a user's monthly salary, allocated across projects ──────────────────
// The NEW salary model (supersedes the per-project ProjectSalary flow). Each user
// has ONE total monthly salary; that total is then ALLOCATED across the projects
// they work on (by percent or fixed amount) via UserSalaryAllocation lines. The
// allocations are informational splits of the total — they need not sum to it
// (the UI shows any unallocated remainder).
model UserSalary {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // One salary per user. Cascade-deleted with the user. userId already implies
  // the tenant, so this stays a plain global unique.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The user's total monthly pay, in minor units, in `currency`.
  totalCents Int    @default(0)
  currency   String @default("USD")

  // Whether this salary is currently in effect (deactivate instead of delete).
  active Boolean @default(true)

  // The day this salary takes effect.
  effectiveFrom DateTime @default(now())

  allocations UserSalaryAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Payroll: one allocation line of a user's salary to a project ─────────────────
// Splits part of a UserSalary across a project — EITHER a percent of the total
// (percentBps) OR a fixed amount (amountCents); exactly one is set, mirroring
// ProjectShareLine. Cascade-deleted with the salary; SetNull-safe per project.
model UserSalaryAllocation {
  id String @id @default(cuid())

  salaryId String
  salary   UserSalary @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  // The project this slice is allocated to. Cascade-deleted if the project goes.
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Exactly one of these is set. percentBps = basis points of the total salary
  // (4000 = 40%); amountCents = a fixed slice in the salary's currency.
  percentBps  Int?
  amountCents Int?

  // Display order within the salary (0-based).
  position Int @default(0)

  // One allocation per (salary, project) — a project appears at most once.
  @@unique([salaryId, projectId])
  @@index([salaryId])
  @@index([projectId])
}

// ── Finance: a project income line ──────────────────────────────────────────────
// One source of a project's income — a label ("Milestone 1", "Retainer", …) plus
// an amount in the project's currency (minor units). The project's total revenue
// is the sum of its income lines (cached on Project.revenueCents). Cascade-deleted
// with the project; ordered for stable display.
model ProjectIncomeLine {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label       String
  amountCents Int    @default(0)

  // Display + entry order within the project (0-based).
  position Int @default(0)

  createdAt DateTime @default(now())

  @@index([projectId])
}

// ── Finance: a project "share" line ─────────────────────────────────────────────
// An amount carved out of a project's revenue BEFORE payroll — the company cut,
// reinvestment, tax, a bonus pot, etc. Each line is either a PERCENT of revenue
// (percentBps, basis points: 4000 = 40%) or a FIXED amount (amountCents); never
// both. The salary pool that's left = revenue − sum(resolved lines). Cascade-
// deleted with the project; ordered for stable display and so percent lines can
// be read top-to-bottom.
model ProjectShareLine {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label String

  // Exactly one of these is set (the other is null): a percent of revenue in
  // basis points, OR a fixed minor-unit amount in the project's currency.
  percentBps  Int?
  amountCents Int?

  // Display + evaluation order within the project (0-based).
  position Int @default(0)

  createdAt DateTime @default(now())

  @@index([projectId])
}

// ── White-label branding ────────────────────────────────────────────────────
// A per-TENANT override for the brand identity (name, colors, logo, contact).
// Env vars (lib/brand.ts) provide the defaults so a fresh tenant works before
// this row exists; an Admin can edit their tenant's row at runtime to rebrand
// without a redeploy. resolveBrand(tenantId) (lib/branding.ts) merges any
// non-null field here over the env defaults. One row per tenant (tenantId
// unique), written via upsert.
model BrandingSettings {
  id String @id @default(cuid())

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyName String?
  tagline     String?
  legalName   String?
  website     String?
  emailDomain String?

  // Hosted logo image URL (Vercel Blob or data URL); null = use the SVG mark.
  logoUrl String?

  // Theme/brand accent as "#rrggbb". Drives the live --c-accent* CSS vars and
  // the (print-safe) invoice accent.
  accentHex String?

  updatedAt DateTime @updatedAt
  updatedBy String? // user id of the admin who last saved
}

// ── Integrations ──────────────────────────────────────────────────────────────
// Per-tenant enablement + config for the third-party app tiles on /tools (Slack,
// GitHub, Jira, …). The catalog (icons, default homepage, copy) lives in code
// (lib/integrations.ts); this table stores only the per-tenant state an Admin
// sets: whether it's enabled and an optional workspace URL/key to deep-link to.
// One row per (tenant, provider). A provider with NO row is treated as disabled
// — the catalog defines what's *available*, this defines what's *on*.
model Integration {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Stable catalog key, e.g. "slack" | "github" | "jira". Matches a Provider in
  // lib/integrations.ts; unknown keys are ignored when rendering.
  provider String

  // Whether this tenant has switched the integration on.
  enabled Boolean @default(false)

  // Optional per-tenant workspace URL the tile deep-links to instead of the
  // provider's public homepage, e.g. "https://acme.slack.com". Null = use the
  // catalog default href.
  workspaceUrl String?

  // Encrypted credential (e.g. a GitHub PAT), AES-256-GCM via lib/cryptoBox.ts.
  // NEVER selected into client-facing payloads — only read server-side when
  // calling the provider's API. Null = not yet connected.
  secret String?

  // Non-secret per-provider config as JSON, e.g. GitHub's { org, repos: [] }.
  // Shape is provider-specific and validated in code, not the DB.
  config Json?

  updatedAt DateTime @updatedAt
  updatedBy String? // user id of the admin who last saved

  @@unique([tenantId, provider])
  @@index([tenantId])
}

// ── Google Drive (per-USER connection) ────────────────────────────────────────
// Unlike the tenant-wide Integration row (which is the admin on/off switch for
// the Drive *tile*), this is per individual user: each person connects THEIR own
// Google account via OAuth so files they upload in the portal land in THEIR
// Drive. One row per user. The refresh token is encrypted at rest (cryptoBox);
// tenantId is carried so the row is tenant-scopable like the other models.
model GoogleDriveConnection {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // The owning user — one connection per user.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The connected Google account's email (display only).
  googleEmail String?

  // Space-separated OAuth scopes Google actually granted on the last consent
  // (from the token response). Lets the UI detect "connected for Drive but not
  // Gmail" and prompt a reconnect when scopes are added. Null = pre-dates this
  // field (treat as Drive-only / unknown). See lib/integrations/google.ts.
  googleScopes String?

  // Encrypted OAuth refresh token (AES-256-GCM via lib/cryptoBox.ts). Used to
  // mint short-lived access tokens. NEVER returned to the client.
  refreshToken String

  // Optional Drive folder id to upload into (else the Drive root / "My Drive").
  // This is the portal's MAIN folder; the section/category subfolders below live
  // inside it (see folderMap).
  folderId   String?
  folderName String?

  // Cache of the auto-created subfolder tree, mapping a logical path to its Drive
  // folder id — e.g. { "Projects": "1Ab…", "Documents": "1Cd…",
  // "Documents/Legal": "1Ef…", "Invoices": "1Gh…" }. Top-level sections are
  // created when the main folder is set; per-category subfolders are created
  // lazily on first use and added here. See lib/integrations/driveTree.ts.
  folderMap  Json?

  // Link sharing on the portal's destination subfolder. true = "anyone with the
  // link can view" (an `anyone` reader permission is applied to the subfolder, so
  // uploads inherit it and their webViewLink opens without sign-in); false =
  // Restricted (only people explicitly granted access — the private default Drive
  // behavior). New folders default to true (see setTenantDriveFolder).
  folderShared Boolean @default(true)

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ── Slack (tenant-wide OAuth connection) ──────────────────────────────────────
// Unlike Google Drive (per-user), Slack is connected ONCE per workspace via the
// "Add to Slack" OAuth flow: an admin authorizes the portal's Slack app into the
// tenant's Slack workspace and we store the resulting BOT token. Every member's
// portal then talks to that one workspace (list channels, read/post messages),
// and portal events optionally fan out to a chosen channel. One row per tenant.
// The bot token is encrypted at rest (cryptoBox) and never returned to clients.
model SlackConnection {
  id String @id @default(cuid())

  // One Slack connection per tenant (the whole workspace shares it).
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // The connected Slack workspace (display + sanity-check on callback).
  teamId   String
  teamName String?

  // Encrypted Slack bot token (xoxb-…), AES-256-GCM via lib/cryptoBox.ts. Used
  // server-side for chat.postMessage / conversations.* calls. NEVER to the client.
  botToken String

  // The channel portal notifications (task assignments, mentions, …) route to.
  // Null = don't post portal events to Slack. Name kept for display only.
  notifyChannelId   String?
  notifyChannelName String?

  // The admin who authorized the connection (audit/display).
  connectedById String?

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}
