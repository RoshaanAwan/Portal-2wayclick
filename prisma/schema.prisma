// 2WayClick Portal — data model
// PostgreSQL in every environment. Locally, point DATABASE_URL at a local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon's pooled connection; Prisma uses the direct URL for migrations.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  title        String
  department   String
  // Role: SUPER_ADMIN | ADMIN | HR | LEAD | PROJECT_MANAGER | EMPLOYEE
  // (stored as a string; see lib/permissions.ts for the source of truth).
  role         String   @default("EMPLOYEE")
  avatarUrl    String?
  phone        String?
  location     String?
  bio          String?
  // Slack identity, used to attribute Slack check-in/out events to this user.
  // slackUserId is the stable Slack user ID (e.g. "U012ABCDEF"); slackHandle is
  // the human-friendly @name kept only for display/debugging. Either may be set
  // by an admin; the webhook also falls back to matching Slack email → email.
  slackUserId  String?  @unique
  slackHandle  String?
  startDate    DateTime @default(now())
  managerId    String?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]   @relation("ManagerReports")

  createdAt DateTime @default(now())

  // Relations
  sessions           Session[]
  authoredPosts      Announcement[]     @relation("PostAuthor")
  uploadedDocs       Document[]         @relation("DocUploader")
  leaveRequests      LeaveRequest[]     @relation("RequestOwner")
  reviewedRequests   LeaveRequest[]     @relation("RequestReviewer")
  comments           Comment[]
  reactions          Reaction[]
  activities         Activity[]
  readReceipts       AnnouncementRead[]
  createdTasks       Task[]             @relation("TaskCreator")
  taskAssignments    TaskAssignee[]
  taskComments       TaskComment[]
  ownedProjects      Project[]          @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  auditLogs          AuditLog[]         @relation("AuditActor")
  auditedBy          AuditLog[]         @relation("AuditTargetUser")
  notifications      Notification[]     @relation("NotifRecipient")
  triggeredNotifs    Notification[]     @relation("NotifActor")
  attendance         Attendance[]
  createdInvoices    Invoice[]          @relation("InvoiceCreator")
  submittedExpenses  Expense[]          @relation("ExpenseSubmitter")
  reviewedExpenses   Expense[]          @relation("ExpenseReviewer")
  submittedCanteen   CanteenExpense[]   @relation("CanteenSubmitter")
  reviewedCanteen    CanteenExpense[]   @relation("CanteenReviewer")
  projectSalaries    ProjectSalary[]    @relation("SalaryEmployee")

  // The org tree is walked by managerId (Team Pulse, org chart, audit scope).
  // Postgres does not auto-index FK columns, so this is needed for the
  // `WHERE managerId IN (...)` subtree walks to use an index instead of a scan.
  @@index([managerId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Session FK lookup (e.g. cascade deletes, listing a user's sessions).
  @@index([userId])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  category   String   @default("General") // General, Product, People, Policy, Event
  pinned     Boolean  @default(false)
  coverColor String   @default("accent")
  authorId   String
  author     User     @relation("PostAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())

  comments  Comment[]
  reactions Reaction[]
  reads     AnnouncementRead[]

  // The feed orders by (pinned desc, createdAt desc); index the sort key.
  @@index([authorId])
  @@index([createdAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  // Compound unique covers announcementId lookups; index userId for "what has
  // this user read" and cascade deletes.
  @@unique([announcementId, userId])
  @@index([userId])
}

model Comment {
  id             String       @id @default(cuid())
  body           String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())

  // Comments are loaded per-announcement, oldest-first.
  @@index([announcementId, createdAt])
  @@index([authorId])
}

model Reaction {
  id             String       @id @default(cuid())
  emoji          String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The compound unique already covers announcementId-prefixed lookups.
  @@unique([announcementId, userId, emoji])
  @@index([userId])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("General") // HR, Engineering, Finance, Legal, Brand
  fileType    String   @default("pdf") // pdf, doc, sheet, slide, img
  sizeKb      Int      @default(0)
  url         String   @default("#")
  uploaderId  String
  uploader    User     @relation("DocUploader", fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())

  // Library lists newest-first; uploader FK for join + "my uploads".
  @@index([createdAt])
  @@index([uploaderId])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  type       String // Vacation, Sick, Personal, WFH
  startDate  DateTime
  endDate    DateTime
  reason     String?
  // Status: PENDING | APPROVED | DENIED
  status     String    @default("PENDING")
  ownerId    String
  owner      User      @relation("RequestOwner", fields: [ownerId], references: [id])
  reviewerId String?
  reviewer   User?     @relation("RequestReviewer", fields: [reviewerId], references: [id])
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?

  // Team Pulse / org chart ask "who is on APPROVED leave covering today" for a
  // set of owners; the approvals queue filters PENDING. Index the hot paths.
  @@index([ownerId])
  @@index([status, startDate, endDate])
  @@index([reviewerId])
}

// ── Attendance ───────────────────────────────────────────────────────────────
// One row per user per calendar day, driven by Slack check-in/check-out events
// the local bot forwards to POST /api/attendance/slack. The first check-in of a
// day opens the row (sets checkInAt + status PRESENT); a check-out stamps
// checkOutAt and sets status CHECKED_OUT. `day` is the date at midnight (server
// time) and is unique per user so repeated events update the same row instead of
// creating duplicates. See lib/attendance.ts for the recording logic.
model Attendance {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Calendar day this record covers, normalized to midnight (server time).
  day        DateTime
  // First check-in and most recent check-out for the day (null until they happen).
  checkInAt  DateTime?
  checkOutAt DateTime?
  // Status: PRESENT (checked in, not yet out) | CHECKED_OUT.
  status     String    @default("PRESENT")
  // Where the event came from, for provenance ("slack" today; room to grow).
  source     String    @default("slack")
  // Count of raw events received for the day (a person may check in/out twice).
  events     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // One row per person per day; lets the webhook upsert idempotently.
  @@unique([userId, day])
  // Newest-first lookups for the attendance dashboard.
  @@index([day])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verb      String // "posted", "uploaded", "requested", "approved", "joined", "commented"
  target    String // human-readable target
  meta      String? // optional JSON string
  createdAt DateTime @default(now())

  // Dashboard feed reads newest-first; userId for per-person activity joins.
  @@index([createdAt])
  @@index([userId])
}

// ── Audit log ────────────────────────────────────────────────────────────────
// The "track everything" trail for privileged actions. Distinct from Activity
// (which is the social/dashboard feed): AuditLog records WHO did WHAT to WHICH
// entity, with structured before/after detail and the request IP. Only viewable
// by Super Admin (see lib/permissions.ts → can.viewAuditLog).
model AuditLog {
  id           String  @id @default(cuid())
  // Who performed the action. Kept even if the actor is later deleted.
  actorId      String?
  actor        User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Denormalized actor identity so the log survives user deletion.
  actorName    String
  actorRole    String
  // What happened, e.g. "user.create", "user.role_change", "auth.login".
  action       String
  // The kind of entity touched, e.g. "User", "Project", "LeaveRequest".
  entity       String
  entityId     String?
  // Optional human-readable summary + structured JSON detail (before/after).
  summary      String?
  detail       String? // JSON string
  ip           String?
  userAgent    String?
  // Optional: the user this action was performed ON (e.g. the created user).
  targetUserId String?
  targetUser   User?   @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
}

// ── Task board (Trello-style) ──────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  lists   BoardList[]
  // A board may belong to a project (every project gets its own board). The
  // standalone /tasks board has no project.
  project Project?

  // The /tasks page loads the oldest board first.
  @@index([createdAt])
}

// ── Projects ────────────────────────────────────────────────────────────────
// An admin-managed workspace. Each project owns exactly one board, giving it a
// separate Trello-style card section, and has its own roster of members.

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  // 1:1 with the board that holds this project's Trello cards.
  boardId String @unique
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  members ProjectMember[]

  // Public client-share link. Anyone with this opaque token can open a
  // read-only board at /shared/<token> and leave comments / submit requests
  // — no portal login. Nullable so it can be revoked (set to null) and
  // regenerated; @unique so the token is the lookup key. Set at creation.
  shareToken String? @unique

  // Comments & requests left by clients via the share link.
  clientSubmissions ClientSubmission[]

  // Finance: expenses charged to this project, and per-person monthly salaries.
  expenses Expense[]
  salaries ProjectSalary[]

  @@index([ownerId])
}

// ── Client submissions ────────────────────────────────────────────────────────
// A comment or request left by an (unauthenticated) client through a project's
// public share link. Has no User — the client self-identifies with a free-text
// name, denormalized here. A REQUEST also spawns a Backlog card (taskId links
// the two); a COMMENT is attached to an existing card (taskId = the card).
model ClientSubmission {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // COMMENT (on an existing card) | REQUEST (becomes a new Backlog card).
  kind        String
  // Client-supplied display name, e.g. "Jane @ Acme". Never a portal identity.
  clientName  String
  // For REQUEST: the request title. For COMMENT: null (body holds the text).
  title       String?
  body        String

  // The card this submission relates to: the commented card, or the card a
  // request spawned. SetNull (not Cascade) so deleting the card keeps the
  // client's words in the trail.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([taskId])
}

// Many-to-many join: which users belong to a project.
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  // Compound unique covers projectId lookups; index userId for "my projects".
  @@unique([projectId, userId])
  @@index([userId])
}

model BoardList {
  id        String   @id @default(cuid())
  name      String
  // Position of the list within its board (left → right).
  position  Float    @default(0)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  tasks Task[]

  // Lists are read per-board ordered left→right.
  @@index([boardId, position])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  // Position of the card within its list (top → bottom). Fractional so cards
  // can be reordered without rewriting every sibling.
  position    Float     @default(0)
  // Priority: LOW | MEDIUM | HIGH
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  listId      String
  list        BoardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt   DateTime  @default(now())

  assignees         TaskAssignee[]
  comments          TaskComment[]
  // Client-share submissions tied to this card (the request that spawned it,
  // or comments left on it via the public link).
  clientSubmissions ClientSubmission[]

  // Cards are read per-list ordered by position; creator FK for joins.
  @@index([listId, position])
  @@index([creatorId])
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  // Comments loaded per-task, oldest-first.
  @@index([taskId, createdAt])
  @@index([authorId])
}

// ── Notifications ─────────────────────────────────────────────────────────────
// Per-user inbox. Distinct from Activity (a global social feed) and AuditLog
// (privileged-action trail): a Notification is addressed TO one user, carries a
// deep link to the thing that happened, and tracks its own read state. Written
// by lib/notifications.ts → notify(); surfaced in the topbar bell with a live
// (SSE) unread badge.
model Notification {
  id          String    @id @default(cuid())
  // Recipient — whose inbox this lands in.
  userId      String
  user        User      @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  // Who caused it (optional — system notifications have no actor). Denormalized
  // name/avatar are stored so the bell renders without a join even if the actor
  // is later deleted.
  actorId     String?
  actor       User?     @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName   String?
  actorAvatar String?
  // Kind, e.g. "leave.decided", "task.assigned", "task.comment",
  // "announcement.created". Keep grep-able and consistent.
  type        String
  // Human-readable line shown in the bell.
  message     String
  // In-app deep link to the relevant page, e.g. "/requests" or "/tasks".
  link        String?
  // Null until the user reads it.
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Newest-first lookups scoped to a recipient, and unread counts.
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ── Invoices ──────────────────────────────────────────────────────────────────
// A bill an Admin / Super Admin raises for a client and sends out. The client is
// captured as free-text (name + email + address) — there is no Client identity
// in the system; this mirrors ClientSubmission's denormalized client name.
//
// Money is stored as integer minor units (cents) in `currency`, never a float —
// 1234 + "USD" means $12.34. Totals are derived from the line items at write
// time and cached on the invoice (subtotalCents/taxCents/totalCents) so a
// printed/shared invoice is a stable snapshot even if rounding logic later
// changes. See lib/invoices.ts for the math, numbering, and formatting.
model Invoice {
  id     String @id @default(cuid())
  // Human-facing sequential number, e.g. "INV-0007". Unique, assigned at
  // creation by counting existing invoices (see lib/invoices.ts → nextNumber).
  number String @unique

  // Free-text client (no portal identity). Email/address are optional.
  clientName    String
  clientEmail   String?
  clientAddress String?

  // Optional human note shown on the invoice (terms, thank-you, etc.).
  notes String?

  // Status: DRAFT (not yet finalized) | SENT (issued to client) | PAID |
  // CANCELLED. Drives the badge and which actions are offered.
  status String @default("DRAFT")

  // ISO 4217 currency code; all *Cents fields are in this currency's minor unit.
  currency String @default("USD")

  // Cached totals (minor units). Derived from items; recomputed on every edit.
  subtotalCents Int @default(0)
  // Tax as a basis-point rate (e.g. 825 = 8.25%) and the resulting amount.
  taxRateBps Int @default(0)
  taxCents   Int @default(0)
  totalCents Int @default(0)

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  // Stamped when status first moves to SENT (for "sent X ago").
  sentAt DateTime?
  // Stamped when status moves to PAID.
  paidAt DateTime?

  // Public, login-less link a client opens to view the invoice at
  // /invoices/shared/<token>. Opaque + unguessable; nullable so it can be
  // revoked/regenerated. @unique so the token is the lookup key.
  shareToken String? @unique

  // Stripe payment linkage. stripeSessionId is the most recent Checkout Session
  // opened for this invoice (used to resume an in-flight payment and to map a
  // webhook event back to the invoice); stripePaymentIntentId is stamped once a
  // payment succeeds, for reconciliation/refunds in the Stripe dashboard. Both
  // null until the client starts/finishes paying.
  stripeSessionId       String?
  stripePaymentIntentId String?

  // Who raised it. Kept (denormalized name) even if the user is later removed.
  creatorId   String?
  creator     User?   @relation("InvoiceCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  creatorName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InvoiceItem[]

  // The list orders newest-first; status filters the dashboard counts.
  @@index([createdAt])
  @@index([status])
}

// A single billable line on an invoice. Amounts are integer minor units.
model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  // Quantity is whole units (e.g. hours, licenses). Price is per-unit, in minor
  // units. amountCents is qty * unitPriceCents, cached so the row is a snapshot.
  quantity       Int @default(1)
  unitPriceCents Int @default(0)
  amountCents    Int @default(0)
  // Display order of the line within the invoice (top → bottom).
  position Int @default(0)

  @@index([invoiceId, position])
}

// Many-to-many join: who is assigned to a card (Trello "members").
model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  // Compound unique covers taskId lookups. Team Pulse / org chart query
  // `WHERE userId IN (...)` to score each person's load, so index userId alone.
  @@unique([taskId, userId])
  @@index([userId])
}

// ── Finance: expenses ──────────────────────────────────────────────────────────
// A general (non-canteen) expense claim raised by an Admin-tier user and decided
// by a *different* Admin-tier user — same two-party approval shape as
// LeaveRequest. Money is integer minor units (cents) in `currency`, never a
// float, mirroring Invoice. An expense may optionally be charged to a Project
// (SetNull on project delete so the claim survives) and carry a receipt slip
// (url/name/size, uploaded via POST /api/finance/upload to Vercel Blob).
// See lib/finance.ts for the statuses, categories, money helpers, and validation.
model Expense {
  id    String @id @default(cuid())
  title String

  // One of lib/finance.ts → EXPENSE_CATEGORIES (Travel, Supplies, …). Stored as
  // a string; validated at write time.
  category String

  amountCents Int    @default(0)
  currency    String @default("USD")

  // Status: PENDING | APPROVED | REJECTED. Drives the badge + available actions.
  status String @default("PENDING")

  notes String?

  // The day the expense was incurred (date at midnight). Defaults to creation.
  spentOn DateTime @default(now())

  // Optional receipt slip (Vercel Blob URL or dev data URL) + its metadata.
  slipUrl    String?
  slipName   String?
  slipSizeKb Int?

  // Optional project this expense is charged to. SetNull so deleting a project
  // keeps the expense record (just unlinks it).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Who submitted it (denormalized name survives user deletion).
  submitterId   String?
  submitter     User?   @relation("ExpenseSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  submitterName String

  // Who decided it (null until decided). Denormalized name like the submitter.
  reviewerId   String?
  reviewer     User?   @relation("ExpenseReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerName String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The list orders newest-first; status filters the approval queue; projectId
  // for the per-project cost rollup; submitterId for "my claims".
  @@index([createdAt])
  @@index([status])
  @@index([projectId])
  @@index([submitterId])
}

// ── Finance: canteen expenses ──────────────────────────────────────────────────
// A dedicated module, separate from the general Expense above: a meal/canteen
// spend with its own fields (vendor, headcount, meal date) and a REQUIRED slip.
// Same two-party PENDING → APPROVED/REJECTED approval workflow. Money is integer
// minor units (cents). See lib/finance.ts for validation + helpers.
model CanteenExpense {
  id     String @id @default(cuid())
  // The canteen / vendor / restaurant the meal was from.
  vendor String

  amountCents Int    @default(0)
  currency    String @default("USD")

  // How many people the meal covered (≥1) — lets per-head cost be derived.
  headcount Int @default(1)

  // Status: PENDING | APPROVED | REJECTED.
  status String @default("PENDING")

  notes String?

  // The day the meal happened (date at midnight). Defaults to creation.
  mealDate DateTime @default(now())

  // The slip is REQUIRED for a canteen expense (non-null columns).
  slipUrl    String
  slipName   String
  slipSizeKb Int    @default(0)

  submitterId   String?
  submitter     User?   @relation("CanteenSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  submitterName String

  reviewerId   String?
  reviewer     User?     @relation("CanteenReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerName String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([submitterId])
}

// ── Finance: per-project salaries ──────────────────────────────────────────────
// An employee's monthly salary on a given project. One employee may have a salary
// on several projects (and several rows over time as pay changes), so the cost of
// a project's payroll is the sum of its active salaries. Money is integer minor
// units (cents). Only ONE row per (project, employee) — editing pay updates the
// same row; superseding history is out of scope. Cascade on project delete (the
// salary has no meaning without its project); SetNull on user delete keeps the
// row (with the denormalized name) for the cost total.
model ProjectSalary {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // The employee this salary is for. SetNull on delete; name is denormalized.
  userId   String?
  user     User?   @relation("SalaryEmployee", fields: [userId], references: [id], onDelete: SetNull)
  userName String

  amountCents Int    @default(0)
  currency    String @default("USD")

  // Whether this salary currently counts toward the project's payroll cost.
  // Deactivating (instead of deleting) keeps the record while excluding it.
  active Boolean @default(true)

  // The day this salary takes effect.
  effectiveFrom DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One salary row per person per project; reverse lookup "this person's
  // salaries"; index projectId for the per-project roster + cost rollup.
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}
